	// case 1: verify if empty cart is redirected to collections page
	@Test(priority = 1)
	public void emptyCart() {
		lp = new loginPage(driver);
		hp = new homePage(driver);
		//lp.goToWebsite();
		hp.clickCartIcon();
		cartDrawer c = new cartDrawer(driver);
		c.clickContinueShopping();
		String expected = "https://nexxus.in/collections/all";
		String actual = driver.getCurrentUrl();
		Assert.assertEquals(expected, actual, "user fails to redirect to collections page");

	}
	//Case 2: Verify if user is able to click on login button from cart drawer and navigate to login page
	@Test(priority = 2)
	public void cartDrawerLoginButton() throws Exception {
		hp.clickCartIcon();
		cartDrawer c = new cartDrawer(driver);
		c.clickLoginLinkCartDrawer();
		String expectedUrl = "https://nexxus.in/account/login";
		String actualUrl = driver.getCurrentUrl();
		Assert.assertEquals(actualUrl, expectedUrl, "user fails to navigate to login page");
		
	}
